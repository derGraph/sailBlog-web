{
  "compilerOptions": {
    "outDir": "build",
    "target": "esnext",
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "baseUrl": ".",
    "paths": {
      "@prisma-custom/client": ["../prisma/generated/client.js"]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true 
  },
  "include": ["./*", "../prisma/generated/**/*"],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}